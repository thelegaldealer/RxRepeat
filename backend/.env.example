# ============================
# UniMaster Backend — .env.example
# Copy this to .env and fill in the values
# ============================

# Core Django
SECRET_KEY=django-insecure-CHANGE-ME-TO-A-REAL-SECRET-KEY
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Render provides DATABASE_URL automatically)
DATABASE_URL=sqlite:///db.sqlite3

# CORS — comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (for OTP verification)
# For production, use SendGrid SMTP or AWS SES:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@unimaster.app
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Google Cloud Storage (optional — for file uploads)
# GS_BUCKET_NAME=unimaster-storage
# GS_PROJECT_ID=your-project-id
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Google OAuth (for frontend Sign-in with Google)
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Gemini AI (for AI Professor feature)
# GEMINI_API_KEY=your-gemini-api-key
